# ========================================
# Cassandra Docker 环境变量配置文件
# ========================================
# 说明：复制此文件为 .env 并根据需要修改配置值
# 使用方式：docker-compose 会自动读取此文件中的变量
# ========================================

# ----------------------------------------
# 集群配置
# ----------------------------------------
# 集群名称 (集群中所有节点必须相同)
CASSANDRA_CLUSTER_NAME=MyCluster

# 广播地址 (多节点部署时设置为容器主机名或宿主机 IP)
CASSANDRA_BROADCAST_ADDRESS=localhost

# 是否启动 Thrift RPC (已废弃，一般设为 false)
CASSANDRA_START_RPC=false

# 虚拟节点令牌数 (建议 256 或 512)
CASSANDRA_NUM_TOKENS=256

# ----------------------------------------
# JVM 配置
# ----------------------------------------
# JVM 最大堆大小 (生产环境建议设置为系统内存的 1/4，最大不超过 8G)
MAX_HEAP_SIZE=512M

# JVM 新生代大小 (建议为最大堆的 1/4 到 1/3)
HEAP_NEWSIZE=100M

# 其他 JVM 选项
JVM_OPTS=-XX:+UseG1GC

# ----------------------------------------
# 端口配置
# ----------------------------------------
# CQL 查询端口 (客户端连接)
CQL_PORT=9042

# JMX 监控端口
JMX_PORT=7199

# 节点间传输端口 (集群通信)
TRANSPORT_PORT=7000

# ----------------------------------------
# 多节点集群配置 (仅集群部署时需要)
# ----------------------------------------
# 节点 1 配置
# NODE1_BROADCAST_ADDRESS=cassandra-node1
# NODE1_SEEDS=cassandra-node1

# 节点 2 配置
# NODE2_BROADCAST_ADDRESS=cassandra-node2
# NODE2_SEEDS=cassandra-node1,cassandra-node2

# 节点 3 配置
# NODE3_BROADCAST_ADDRESS=cassandra-node3
# NODE3_SEEDS=cassandra-node1,cassandra-node2

# ----------------------------------------
# 数据中心和机架配置 (多 DC 部署时需要)
# ----------------------------------------
# CASSANDRA_DC=dc1
# CASSANDRA_RACK=rack1
# CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch

# ----------------------------------------
# Bitnami 镜像专用配置 (如使用 bitnami/cassandra)
# ----------------------------------------
# CASSANDRA_USER=cassandra
# CASSANDRA_PASSWORD=your_secure_password
# ALLOW_EMPTY_PASSWORD=no
# CASSANDRA_DATACENTER=dc1
# CASSANDRA_INTERNODE_ENCRYPTION=none
# CASSANDRA_CLIENT_ENCRYPTION=false
